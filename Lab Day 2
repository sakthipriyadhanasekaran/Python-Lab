#Task 6
#Simple Calculator 
a = float(input("Enter a number: "))
b = float(input("Enter b number: "))

print("1.Add")
print("2.Subtract")
print("3.Multiply")
print("4.Divide")

choice = int(input("Enter choice: "))

if choice == 1:
    print("Answer =", a + b)
elif choice == 2:
